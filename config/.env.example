# Copy to config/.env and fill in real values. config/.env is gitignored --
# never commit real secrets. Every variable here is referenced by a `*_env`
# field in config.example.yaml / partners.example.yaml (or its real
# config.yaml / partners.yaml counterpart).

# --- config.yaml: crypto ---
# Passphrase for our own OpenPGP private key (crypto.passphrase_env).
NAESB_GPG_PASSPHRASE=changeme

# --- config.yaml: sinks.s3 (only needed if sinks.s3.enabled: true) ---
# Credentials for the S3-compatible bucket (access_key_env / secret_key_env).
NAESB_S3_ACCESS_KEY=changeme
NAESB_S3_SECRET_KEY=changeme

# --- config.yaml: database ---
# Postgres connection string (database.url_env), e.g.:
# postgresql://naesb:naesb@localhost:5432/naesb
NAESB_DATABASE_URL=postgresql://naesb:naesb@localhost:5432/naesb
#
# Optional: only needed if you set database.username_env/password_env in
# config.yaml to keep credentials separate from NAESB_DATABASE_URL above
# (e.g. NAESB_DATABASE_URL=postgresql://localhost:5432/naesb with no
# embedded user:pass). Uncomment and set both database.username_env and
# database.password_env in config.yaml to NAESB_DATABASE_USERNAME /
# NAESB_DATABASE_PASSWORD to use these.
# NAESB_DATABASE_USERNAME=naesb
# NAESB_DATABASE_PASSWORD=naesb

# --- config.yaml: internal_api ---
# Basic auth credentials protecting internal-only endpoints (GET /api/partners).
NAESB_INTERNAL_API_USERNAME=changeme
NAESB_INTERNAL_API_PASSWORD=changeme

# --- partners.yaml: acme-pipeline ---
# Password we send when calling acme-pipeline's endpoint (outbound_auth.password_env).
NAESB_ACME_PASSWORD=changeme
# API key we require from acme-pipeline when they call our /inbound endpoint (inbound_auth.key_env).
NAESB_ACME_INBOUND_KEY=changeme

# Add one password_env/key_env pair per partner as you add partners to partners.yaml.
